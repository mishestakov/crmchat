diff (CRMchat patch)
--- a/src/util/crmchat.ts	1970-01-01 03:00:00.000000000 +0300
+++ b/src/util/crmchat.ts	2026-04-24 15:07:48.635661409 +0300
@@ -0,0 +1,231 @@
+/* eslint-disable no-console */
+/**
+ * [CRMchat] postMessage-мост между TWA-iframe и нашим CRM-родителем.
+ *
+ * URL-контракт: ?accountId=...&theme=...&parentOrigin=https://crm.example.com
+ *
+ * Контракт сообщений:
+ *   PARENT → IFRAME:
+ *     { type: 'sessionResponse', session: ApiSessionData }
+ *     { type: 'openChat', id: string }
+ *     { type: 'openChatByUsername', username: string }
+ *
+ *   IFRAME → PARENT:
+ *     { type: 'sessionRequest' }              — на старте, ждём sessionResponse
+ *     { type: 'sessionRequestFailed' }        — таймаут получения сессии
+ *     { type: 'authState', state: ... }       — apiUpdate.updateAuthorizationState
+ *     { type: 'authStateLegacy', state: ... } — global.auth.state
+ *     { type: 'connectionState', state: ... } — apiUpdate.updateConnectionState
+ *     { type: 'syncState', isSynced: boolean } — chat list загружен (можно openChat)
+ *     { type: 'chatOpened', chat, info, userId, username } — юзер открыл чат
+ *     { type: 'chatUnreadState', peerId, username, unreadCount, synced }
+ */
+import { addCallback } from '../lib/teact/teactn';
+import {
+  addActionHandler, getActions, getGlobal,
+} from '../global';
+
+import type { ApiChatFullInfo, ApiSessionData, ApiUserFullInfo } from '../api/types';
+import type { ActionPayloads, GlobalState } from '../global/types';
+import { MAIN_THREAD_ID } from '../api/types';
+
+import { selectThreadReadState } from '../global/selectors/threads';
+import { getCurrentTabId } from './establishMultitabRole';
+
+const SESSION_REQUEST_TIMEOUT_MS = 20_000;
+const ACTION_AVAILABILITY_POLL_MS = 100;
+const ACTION_AVAILABILITY_MAX_TRIES = 100;
+
+// Origin родительского CRM — приходит URL-параметром при mount'е iframe'а.
+// Используется и как whitelist для входящих postMessage, и как targetOrigin
+// для исходящих. Без него iframe не работает: фейлим safe (ничего не шлём,
+// ничего не принимаем).
+const PARENT_ORIGIN = new URLSearchParams(self.location.search).get('parentOrigin') || '';
+if (!PARENT_ORIGIN) {
+  console.error('[CRMchat] parentOrigin URL param отсутствует — мост работать не будет');
+}
+
+function isAllowedOrigin(origin: string): boolean {
+  return Boolean(PARENT_ORIGIN) && origin === PARENT_ORIGIN;
+}
+
+function crmChatLog(...args: any[]) {
+  console.info('\x1b[44m\x1b[37m[ CRMCHAT ]\x1b[0m', ...args);
+}
+
+function sendToCrm(data: any) {
+  if (!PARENT_ORIGIN) return;
+  crmChatLog('→ CRM', data);
+  window.parent.postMessage(data, PARENT_ORIGIN);
+}
+
+// === sessionResponse: ждём pre-fetched session от родителя ===
+let resolveSession: (session: ApiSessionData) => void;
+const sessionPromise = new Promise<ApiSessionData>((resolve) => {
+  resolveSession = resolve;
+});
+
+export async function requestSessionFromCrmChat(): Promise<ApiSessionData> {
+  sendToCrm({ type: 'sessionRequest' });
+  try {
+    return await Promise.race([
+      sessionPromise,
+      new Promise<never>((_, reject) => {
+        setTimeout(() => reject(new Error('Session request timed out')), SESSION_REQUEST_TIMEOUT_MS);
+      }),
+    ]);
+  } catch (e) {
+    sendToCrm({ type: 'sessionRequestFailed' });
+    throw e;
+  }
+}
+
+// === openChat / openChatByUsername: ждём пока action доступен ===
+async function callActionWhenAvailable<A extends keyof ActionPayloads>(
+  action: A,
+  data: ActionPayloads[A],
+) {
+  for (let i = 0; i < ACTION_AVAILABILITY_MAX_TRIES; i++) {
+    if (typeof getActions()[action] === 'function') {
+      getActions()[action](data as any);
+      return;
+    }
+    await new Promise((resolve) => setTimeout(resolve, ACTION_AVAILABILITY_POLL_MS));
+  }
+}
+
+window.addEventListener('message', (event) => {
+  if (!isAllowedOrigin(event.origin)) return;
+
+  crmChatLog('← CRM', event.data);
+
+  const { type } = event.data;
+
+  if (type === 'sessionResponse') {
+    resolveSession(event.data.session);
+    return;
+  }
+  if (type === 'openChat') {
+    callActionWhenAvailable('openChat', { id: String(event.data.id) });
+    return;
+  }
+  if (type === 'openChatByUsername') {
+    callActionWhenAvailable('openChatByUsername', { username: event.data.username });
+  }
+});
+
+// === Эмиты в родителя по изменениям global state ===
+type CurrentState = {
+  authState: GlobalState['auth']['state'];
+  isSynced: boolean;
+  currentChatId?: string;
+  currentChatUnreadCount?: number;
+};
+const current: CurrentState = {
+  authState: undefined,
+  isSynced: false,
+  currentChatId: undefined,
+  currentChatUnreadCount: undefined,
+};
+
+addCallback(() => {
+  const global = getGlobal();
+
+  // authStateLegacy — глобальный auth flow (готов / не готов)
+  if (global.auth.state !== current.authState) {
+    current.authState = global.auth.state;
+    sendToCrm({ type: 'authStateLegacy', state: current.authState });
+  }
+
+  // isSynced=true означает что chat list загружен и можно безопасно openChat.
+  // Без этого сигнала родитель шлёт openChat когда auth=ready но state ещё пуст
+  // → TWA падает с "Cannot read properties of undefined (reading 'threadsById')".
+  if (Boolean(global.isSynced) !== current.isSynced) {
+    current.isSynced = Boolean(global.isSynced);
+    sendToCrm({ type: 'syncState', isSynced: current.isSynced });
+  }
+
+  const messageLists = global.byTabId[getCurrentTabId()]?.messageLists;
+  const chatId = messageLists?.[messageLists.length - 1]?.chatId;
+  const chat = chatId ? global.chats.byId[chatId] : undefined;
+
+  // Unread-counter текущего чата
+  const unreadCount = chat
+    ? selectThreadReadState(global, chat.id, MAIN_THREAD_ID)?.unreadCount
+    : undefined;
+  if (unreadCount !== current.currentChatUnreadCount) {
+    current.currentChatUnreadCount = unreadCount;
+    sendToCrm({
+      type: 'chatUnreadState',
+      peerId: chat?.id,
+      username: chat?.usernames?.[0]?.username,
+      unreadCount,
+      synced: global.isSynced,
+    });
+  }
+
+  // ChatOpened — юзер переключил чат. Не шлём avatar (CRM сам подтягивает
+  // из своих данных), не делаем async fetch — callback синхронный, нет race.
+  if (chat?.id !== current.currentChatId) {
+    current.currentChatId = chat?.id;
+    const fullInfo: ApiUserFullInfo | ApiChatFullInfo | undefined = chat
+      ? global.users.fullInfoById[chat.id] ?? global.chats.fullInfoById[chat.id]
+      : undefined;
+
+    let peerType: 'user' | 'group' | 'other' = 'other';
+    switch (chat?.type) {
+      case 'chatTypePrivate':
+        peerType = 'user';
+        break;
+      case 'chatTypeBasicGroup':
+      case 'chatTypeSuperGroup':
+        peerType = 'group';
+        break;
+    }
+
+    const info = chat ? {
+      type: peerType,
+      peerId: chat.id,
+      username: chat.usernames?.[0]?.username,
+      fullName: chat.title,
+      description: fullInfo && 'bio' in fullInfo
+        ? fullInfo.bio
+        : (fullInfo && 'about' in fullInfo ? fullInfo.about : undefined),
+    } : undefined;
+
+    sendToCrm({
+      type: 'chatOpened',
+      chat,
+      info,
+      userId: chat?.id,
+      username: chat?.usernames?.[0]?.username,
+    });
+  }
+});
+
+// apiUpdate handler — авто-форвард authState/connectionState родителю
+addActionHandler('apiUpdate', (global, actions, update): void => {
+  switch (update['@type']) {
+    case 'updateAuthorizationState':
+      sendToCrm({ type: 'authState', state: update.authorizationState });
+      break;
+    case 'updateConnectionState':
+      sendToCrm({ type: 'connectionState', state: update.connectionState });
+      break;
+  }
+});
+
+// === Worker patch: пробрасываем accountId в воркеры (для storage-префиксов) ===
+// _dcAuth/_dcDomain (donor) НЕ добавляем — у нас нет MTProto-прокси.
+const accountIdParam = new URLSearchParams(self.location.search).get('accountId') ?? '';
+
+const OriginalWorker = window.Worker;
+window.Worker = class PatchedWorker extends OriginalWorker {
+  constructor(url: string | URL, options?: WorkerOptions) {
+    const newUrl = url instanceof URL ? url : new URL(url, self.location.href);
+    newUrl.searchParams.set('accountId', accountIdParam);
+    super(newUrl, options);
+  }
+} satisfies typeof Worker;
+
