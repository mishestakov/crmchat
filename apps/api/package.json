{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --hot src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:seed": "bun --env-file=../../.env run src/seed.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.19.0",
    "@repo/core": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "postgres": "^3.4.4",
    "telegram": "^2.26.22",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.7.0"
  }
}
