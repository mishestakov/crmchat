{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --hot src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:seed": "bun --env-file=../../.env run src/seed.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "@repo/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "jose": "^6.2.3",
    "postgres": "^3.4.4",
    "tdl": "^8.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
