+void Requests::on_request(uint64 id, const td_api::getRawAuthKey &request) {
+  CHECK_IS_USER();
+  if (!DcId::is_valid(request.dc_id_)) {
+    return send_error_raw(id, 400, "Invalid DC id");
+  }
+  auto auth_key = AuthDataShared::get_auth_key_for_dc(DcId::internal(request.dc_id_));
+  if (auth_key.empty()) {
+    return send_error_raw(id, 404, "No auth_key for the requested DC");
+  }
+  send_closure(td_actor_, &Td::send_result, id,
+               td_api::make_object<td_api::authKeyData>(request.dc_id_, auth_key.key()));
+}
+
+void Requests::on_request(uint64 id, const td_api::getMtprotoSession &request) {
+  CHECK_IS_USER();
+  auto main_dc = G()->net_query_dispatcher().get_main_dc_id();
+  if (!main_dc.is_exact()) {
+    return send_error_raw(id, 404, "Main DC is not initialized yet");
+  }
+  vector<td_api::object_ptr<td_api::authKeyData>> keys;
+  for (int32 raw_dc_id = 1; raw_dc_id <= 5; ++raw_dc_id) {
+    auto auth_key = AuthDataShared::get_auth_key_for_dc(DcId::internal(raw_dc_id));
+    if (!auth_key.empty()) {
+      keys.push_back(td_api::make_object<td_api::authKeyData>(raw_dc_id, auth_key.key()));
+    }
+  }
+  if (keys.empty()) {
+    return send_error_raw(id, 404, "No auth_key for any DC");
+  }
+  send_closure(td_actor_, &Td::send_result, id,
+               td_api::make_object<td_api::mtprotoSession>(main_dc.get_raw_id(), std::move(keys)));
+}
+
 void Requests::on_request(uint64 id, const td_api::terminateSession &request) {
   CHECK_IS_USER();
   CREATE_OK_REQUEST_PROMISE();
