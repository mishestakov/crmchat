@@ -14146,6 +14152,12 @@ removeMessageSenderBotVerification bot_user_id:int53 verified_id:MessageSender =
 //@description Returns all active sessions of the current user
 getActiveSessions = Sessions;
 
+//@description Returns raw MTProto auth_key material for the requested data center. crmchat extension. Returns 404 if the auth_key for the DC has not been negotiated yet @dc_id Target Telegram DC id (1..5)
