+void Requests::on_request(uint64 id, const td_api::getRawAuthKey &request) {
+  CHECK_IS_USER();
+  if (!DcId::is_valid(request.dc_id_)) {
+    return send_error_raw(id, 400, "Invalid DC id");
+  }
+  auto auth_key = AuthDataShared::get_auth_key_for_dc(DcId::internal(request.dc_id_));
+  if (auth_key.empty()) {
+    return send_error_raw(id, 404, "No auth_key for the requested DC");
+  }
+  send_closure(td_actor_, &Td::send_result, id,
+               td_api::make_object<td_api::authKeyData>(request.dc_id_, auth_key.key()));
+}
+
 void Requests::on_request(uint64 id, const td_api::terminateSession &request) {
