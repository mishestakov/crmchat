DATABASE_URL=postgres://crmchat:crmchat@localhost:5432/crmchat
PORT=3000
NODE_ENV=development
# Dev-only auth (POST /v1/_dev/login → подделка сессии). Двойной гейт:
# и NODE_ENV=development, и явный opt-in здесь. На prod — не выставлять.
ALLOW_DEV_AUTH=true

# Telegram MTProto app credentials (https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram Bot deep-link login (см. specs/auth.md). Это login-flow юзеров на
# сайт через @BotFather-бота — обход RKN-блокировки oauth.telegram.org. Не путать
# с TELEGRAM_API_ID/HASH (MTProto-приложение для outreach).
#   TOKEN/USERNAME — выдаёт @BotFather (/newbot). Один бот = один деплой:
#   токен нельзя шарить между окружениями (getUpdates single-consumer).
#   WEBHOOK_SECRET — любая случайная строка; на RU-сервере webhook не доезжает,
#   там работает getUpdates long-polling, но переменная всё равно обязательна
#   (без неё бот не конфигурируется, см. isBotConfigured).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Куда api редиректит после успешного login (frontend origin). Должен совпадать
# с CORS-allowlist в apps/api/src/app.ts.
WEB_ORIGIN=http://localhost:5173

# Origin api для login-кнопки (cross-origin fetch на /v1/auth/tg-bot/*).
# В dev фронт ходит на api напрямую, не через vite-proxy. На прод (один origin)
# — оставить пустым. Пример dev: https://your-tunnel.ngrok-free.dev
VITE_API_BASE=

# YouTube Data API v3 ключ (этап 17 — сбор метрик YouTube-площадок)
YOUTUBE_KEY=

# Google Docs/Drive — согласование креативов (пилот с агентством).
# GOOGLE_SA_KEY_FILE — путь к JSON-ключу сервис-аккаунта.
# GOOGLE_DRIVE_FOLDER_ID — id папки в Общем диске агентства, куда бот создаёт доки
# (из URL папки: drive.google.com/drive/folders/<ID>). Бот должен быть добавлен
# в эту папку «Организатором контента».
GOOGLE_SA_KEY_FILE=
GOOGLE_DRIVE_FOLDER_ID=
