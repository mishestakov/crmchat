DATABASE_URL=postgres://crmchat:crmchat@localhost:5432/crmchat
PORT=3000
NODE_ENV=development
# Dev-only auth (POST /v1/_dev/login → подделка сессии). Двойной гейт:
# и NODE_ENV=development, и явный opt-in здесь. На prod — не выставлять.
ALLOW_DEV_AUTH=true

# Telegram MTProto app credentials (https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# AES-256-GCM ключ для шифрования MTProto session-string'ов в БД (см. lib/crypto.ts).
# Минимум 16 символов, рекомендуется 32+. Сгенерировать:
#   openssl rand -base64 32
# ВАЖНО: потеря секрета = unrecoverable для всех залогиненных TG-аккаунтов.
ENCRYPTION_SECRET=

# Telegram OIDC login (см. specs/auth.md). Бот заводится через @BotFather,
# Allowed URL = TELEGRAM_LOGIN_REDIRECT_URI. Client ID = bot ID, Client Secret
# выдаёт BotFather там же. Это login-flow юзеров на сайт; не путать с
# TELEGRAM_API_ID/HASH (MTProto-приложение для outreach).
TELEGRAM_LOGIN_CLIENT_ID=
TELEGRAM_LOGIN_CLIENT_SECRET=
TELEGRAM_LOGIN_REDIRECT_URI=http://localhost:3000/v1/auth/telegram/callback

# Куда api редиректит после успешного login (frontend origin). Должен совпадать
# с CORS-allowlist в apps/api/src/app.ts.
WEB_ORIGIN=http://localhost:5173

# Origin api для login-кнопки (cross-origin GET на /v1/auth/telegram/start).
# В dev: tg_oidc cookie должен садиться на тот же домен, куда TG потом сделает
# callback (TELEGRAM_LOGIN_REDIRECT_URI). Поэтому login-link не идёт через
# vite-proxy, а уходит напрямую на api. На прод (один origin) — оставить пустым.
# Пример dev: https://your-tunnel.ngrok-free.dev
VITE_API_BASE=
