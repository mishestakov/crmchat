# Скопировать как .env.production и заполнить. На VPS — лежит в /opt/crmchat/.env.production
# (НЕ коммитим, в .gitignore).
#
# Источники секретов:
#   - TELEGRAM_API_ID/HASH — my.telegram.org/apps (можно те же, что в dev)
#   - TELEGRAM_LOGIN_CLIENT_* — @BotFather → бот → Login Widget → Allowed URL
#   - POSTGRES_PASSWORD  — `openssl rand -base64 24` (без / + чтобы в URL не экранировать)

# --- БД -----------------------------------------------------------------
POSTGRES_USER=crmchat
POSTGRES_PASSWORD=__CHANGEME__
POSTGRES_DB=crmchat

# --- Login flow (Telegram Bot deep-link, обход oauth.telegram.org RKN-блока) ---
WEB_ORIGIN=https://tgdesk.su
# Bot API token из @BotFather (полный, формата 123456789:AAH...)
TELEGRAM_BOT_TOKEN=
# Username бота без @
TELEGRAM_BOT_USERNAME=
# Случайный секрет для проверки webhook'а (anti-spoofing)
# openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# --- (deprecated) OIDC через oauth.telegram.org — не используется в РФ из-за RKN ---
TELEGRAM_LOGIN_CLIENT_ID=
TELEGRAM_LOGIN_CLIENT_SECRET=
TELEGRAM_LOGIN_REDIRECT_URI=https://tgdesk.su/v1/auth/telegram/callback

# --- Площадки (мультиплатформенность) -----------------------------------
# YouTube Data API v3 key: console.cloud.google.com → APIs & Services →
# включить «YouTube Data API v3» → Credentials → API key. Нужен для YouTube-
# каналов (синк профиля + метрики постов). Без ключа TikTok работает
# (публичный embed), а YouTube падает «YOUTUBE_KEY не задан».
YOUTUBE_KEY=

# --- MTProto (outreach worker) ------------------------------------------
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# MTProto-прокси для TDLib (опционально). Полная ссылка от @MTProxybot —
# либо tg://proxy?server=...&port=...&secret=..., либо https://t.me/proxy?...
# Нужен когда VPS-IP числится как US/EU в базах TG (привет Timeweb), чтобы
# TG-сервер видел подключение из правильного гео и не запускал anti-fraud.
TG_PROXY_URL=

# --- Синк «Каналы Яндекса» (CPC/CPA → Postgres), см. yt/README.md ---------
# Пароль scoped-юзера pac_sync (пишет только в platform_active_*). Применить
# роль: yt/sql/pac_sync_role.sql. Запуск джоба — systemd-timer (yt/systemd/).
PAC_SYNC_PASSWORD=
# Путь к YT OAuth-токену на хосте (монтируется в pac-sync read-only).
YT_TOKEN_FILE=/root/.yt/token
